{
  "mode": "All",
  "policyRule": {
    "if": {
      "allOf": [
        {
          "anyOf": [
            {
              "field": "type",
              "equals": "Microsoft.Web/sites"
            },
            {
              "field": "type",
              "equals": "Microsoft.Web/sites/slots"
            }
          ]
        },
        {
          "field": "Microsoft.Web/sites/publicNetworkAccess",
          "notEquals": "Disabled"
        },
        {
          "count": {
            "field": "Microsoft.Web/sites/siteConfig.ipSecurityRestrictions[*]",
            "where": {
              "field": "Microsoft.Web/sites/siteConfig.ipSecurityRestrictions[*].action",
              "notEquals": "Allow"
            }
          },
          "greater": 0
        }
      ]
    },
    "then": {
      "effect": "deny"
    }
  },
  "parameters": {},
  "metadata": {
    "category": "App Service",
    "version": "1.0.0",
    "description": "Denies creation of App Service resources if IP security restrictions contain non-Allow actions, unless public network access is disabled."
  }
}